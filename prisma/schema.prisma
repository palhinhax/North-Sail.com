// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  ADMIN
  CLIENT
}

enum Sector {
  RESTAURANT
  HAIR_SALON
  HOTEL
  GYM
  LOCAL_SERVICES
  SMALL_SHOP
  CLINIC
  OTHER
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PENDING
}

enum RequestType {
  NEW_APP
  CHANGE
  SUPPORT
  UPGRADE
  CANCEL
}

enum RequestStatus {
  SUBMITTED
  IN_REVIEW
  IN_DEVELOPMENT
  AWAITING_CLIENT
  READY_FOR_REVIEW
  PUBLISHED
  DONE
  REJECTED
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  ARCHIVED
}

enum DiscountType {
  FREE_PERIOD
  PERCENT
  FIXED
  FREE_SETUP
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         Role     @default(CLIENT)
  createdAt    DateTime @default(now())

  business         Business?
  assignedRequests ServiceRequest[] @relation("AssignedAdmin")
  posts            Post[]
  passwordResets   PasswordResetToken[]
  createdDiscountCodes DiscountCode[] @relation("DiscountCreatedBy")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Business {
  id            String   @id @default(cuid())
  name          String
  sector        Sector
  slug          String   @unique
  domainDesired String?
  customDomain  String?  @unique
  siteUrl       String?
  sitePublished Boolean  @default(false)
  stripeCustomerId String?
  vercelProjectId  String?
  description   String?
  phone         String?
  whatsapp      String?
  address       String?
  logoUrl       String?
  ownerId       String   @unique
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  subscription Subscription?
  requests     ServiceRequest[]
  discountRedemptions DiscountRedemption[]
}

model Plan {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  monthlyPrice Int
  annualPrice  Int
  setupPrice   Int
  setupPromo   Boolean  @default(false)
  description  String
  features     String[]
  active       Boolean  @default(true)

  stripeProductId      String?
  stripePriceMonthlyId String?
  stripePriceAnnualId  String?

  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  businessId       String             @unique
  business         Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  planId           String
  plan             Plan               @relation(fields: [planId], references: [id])
  status           SubscriptionStatus @default(TRIALING)
  billingCycle     BillingCycle       @default(MONTHLY)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  stripeSubscriptionId String?
  isComped     Boolean   @default(false)   // subscrição oferecida via código
  setupWaived  Boolean   @default(false)   // setup isentado via FREE_SETUP
  startedAt        DateTime           @default(now())
  canceledAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model ServiceRequest {
  id             String        @id @default(cuid())
  businessId     String
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type           RequestType   @default(NEW_APP)
  title          String
  description    String
  sector         Sector
  status         RequestStatus @default(SUBMITTED)
  priority       Int           @default(2)
  estimatedHours Float?
  actualHours    Float?
  assignedToId   String?
  assignedTo     User?         @relation("AssignedAdmin", fields: [assignedToId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  publishedAt    DateTime?

  statusEvents RequestStatusEvent[]
  messages     RequestMessage[]
  attachments  Attachment[]
}

model RequestStatusEvent {
  id          String         @id @default(cuid())
  requestId   String
  request     ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  status      RequestStatus
  note        String?
  changedById String?
  createdAt   DateTime       @default(now())
}

model RequestMessage {
  id        String         @id @default(cuid())
  requestId String
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId  String
  body      String
  createdAt DateTime       @default(now())

  attachments Attachment[]
}

model Attachment {
  id           String          @id @default(cuid())
  requestId    String
  request      ServiceRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  messageId    String?
  message      RequestMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploadedById String
  key          String
  fileName     String
  contentType  String
  size         Int
  createdAt    DateTime        @default(now())
}

/// Inbound marketing leads captured from the public lead form.
model Lead {
  id                String     @id @default(cuid())
  businessName      String
  businessType      String
  country           String?
  preferredLanguage String?
  currentSite       String?
  need              String
  email             String
  phone             String?
  locale            String?
  status            LeadStatus @default(NEW)
  createdAt         DateTime   @default(now())

  @@index([status, createdAt])
}

model DiscountCode {
  id              String       @id @default(cuid())
  code            String       @unique
  type            DiscountType

  // PERCENT: 1–100. FIXED: cêntimos. Ignorado em FREE_PERIOD / FREE_SETUP.
  value           Int          @default(0)

  // FREE_PERIOD: meses oferecidos. PERCENT/FIXED: meses de desconto. FREE_SETUP: ignorado.
  durationMonths  Int?

  appliesToPlanIds String[]    @default([])  // vazio = todos os planos
  maxRedemptions   Int?                       // null = ilimitado
  redemptionsUsed  Int         @default(0)
  perAccountLimit  Int         @default(1)

  validFrom        DateTime    @default(now())
  validUntil       DateTime?
  active           Boolean     @default(true)
  notes            String?

  // Só PERCENT/FIXED: criado uma vez na Stripe e reutilizado.
  stripeCouponId        String?
  stripePromotionCodeId String?

  createdById     String?
  createdBy       User?        @relation("DiscountCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  redemptions     DiscountRedemption[]

  @@index([code])
  @@index([active])
}

model DiscountRedemption {
  id            String       @id @default(cuid())
  codeId        String
  code          DiscountCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  businessId    String
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Snapshot do efeito, para auditoria.
  effectType    DiscountType
  effectSummary String       // ex.: "12 meses grátis", "-50% durante 3 meses"
  appliedUntil  DateTime?    // FREE_PERIOD: até quando ficou oferecido
  consumed      Boolean      @default(false) // PERCENT/FIXED/FREE_SETUP: usados no checkout

  redeemedAt    DateTime     @default(now())

  @@index([businessId])
  // perAccountLimit = 1 fica reforçado a nível de BD.
  // Se quiseres permitir perAccountLimit > 1 no futuro, remove este unique e valida só em código.
  @@unique([codeId, businessId])
}
