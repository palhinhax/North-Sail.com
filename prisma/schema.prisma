// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  ADMIN
  CLIENT
}

enum Sector {
  RESTAURANT
  HAIR_SALON
  HOTEL
  GYM
  LOCAL_SERVICES
  SMALL_SHOP
  CLINIC
  OTHER
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PENDING
}

enum RequestType {
  NEW_APP
  CHANGE
  SUPPORT
  UPGRADE
  CANCEL
}

enum RequestStatus {
  SUBMITTED
  IN_REVIEW
  IN_DEVELOPMENT
  AWAITING_CLIENT
  READY_FOR_REVIEW
  PUBLISHED
  DONE
  REJECTED
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  ARCHIVED
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         Role     @default(CLIENT)
  createdAt    DateTime @default(now())

  business         Business?
  assignedRequests ServiceRequest[] @relation("AssignedAdmin")
  posts            Post[]
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Business {
  id            String   @id @default(cuid())
  name          String
  sector        Sector
  slug          String   @unique
  domainDesired String?
  customDomain  String?  @unique
  siteUrl       String?
  sitePublished Boolean  @default(false)
  stripeCustomerId String?
  vercelProjectId  String?
  description   String?
  phone         String?
  whatsapp      String?
  address       String?
  logoUrl       String?
  ownerId       String   @unique
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  subscription Subscription?
  requests     ServiceRequest[]
}

model Plan {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  monthlyPrice Int
  annualPrice  Int
  setupPrice   Int
  setupPromo   Boolean  @default(false)
  description  String
  features     String[]
  active       Boolean  @default(true)

  stripeProductId      String?
  stripePriceMonthlyId String?
  stripePriceAnnualId  String?

  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  businessId       String             @unique
  business         Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  planId           String
  plan             Plan               @relation(fields: [planId], references: [id])
  status           SubscriptionStatus @default(TRIALING)
  billingCycle     BillingCycle       @default(MONTHLY)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  stripeSubscriptionId String?
  startedAt        DateTime           @default(now())
  canceledAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model ServiceRequest {
  id             String        @id @default(cuid())
  businessId     String
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type           RequestType   @default(NEW_APP)
  title          String
  description    String
  sector         Sector
  status         RequestStatus @default(SUBMITTED)
  priority       Int           @default(2)
  estimatedHours Float?
  actualHours    Float?
  assignedToId   String?
  assignedTo     User?         @relation("AssignedAdmin", fields: [assignedToId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  publishedAt    DateTime?

  statusEvents RequestStatusEvent[]
  messages     RequestMessage[]
}

model RequestStatusEvent {
  id          String         @id @default(cuid())
  requestId   String
  request     ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  status      RequestStatus
  note        String?
  changedById String?
  createdAt   DateTime       @default(now())
}

model RequestMessage {
  id        String         @id @default(cuid())
  requestId String
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId  String
  body      String
  createdAt DateTime       @default(now())
}

/// Inbound marketing leads captured from the public lead form.
model Lead {
  id                String     @id @default(cuid())
  businessName      String
  businessType      String
  country           String?
  preferredLanguage String?
  currentSite       String?
  need              String
  email             String
  phone             String?
  locale            String?
  status            LeadStatus @default(NEW)
  createdAt         DateTime   @default(now())

  @@index([status, createdAt])
}
