# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/saas_template"

# Auth.js
AUTH_SECRET="your-auth-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Application
NODE_ENV="development"

# Canonical public site URL (used for SEO canonical, hreflang, sitemap, robots, OG)
NEXT_PUBLIC_SITE_URL="https://www.north-sail.com"

# Optional: forward each new marketing lead as JSON to this URL
# (Slack/Make/Zapier inbound webhook or your own email endpoint). Leads are
# always stored in the database regardless of whether this is set.
LEAD_NOTIFY_WEBHOOK=""

# Resend (transactional email — password reset, etc.)
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=""
# Verified sender. The domain must be verified in Resend.
EMAIL_FROM="NorthSail <no-reply@north-sail.com>"
